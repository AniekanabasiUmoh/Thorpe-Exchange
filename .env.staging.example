# =============================================================================
# STAGING ENVIRONMENT — Railway staging service
# Copy these into your Railway staging service environment variables.
# Connect to a SEPARATE Supabase project and Upstash Redis instance from prod.
# =============================================================================

PORT=3000
NODE_ENV=production

# Staging Supabase (separate project from production)
DATABASE_URL=

# Staging Upstash Redis (separate instance from production)
REDIS_URL=

# Always use mock in staging unless explicitly testing real Breet sandbox
BREET_MOCK=true
BREET_API_KEY=
BREET_API_BASE_URL=https://sandbox.api.breet.io
BREET_WEBHOOK_SECRET=

SPREAD_PERCENT=1.5
MIN_TX_AMOUNT=10
MAX_TX_AMOUNT=10000
MAX_MESSAGES_PER_MINUTE=5
MAX_TX_PER_DAY=3
MAX_DAILY_VOLUME_NGN=500000

# Staging bot token (create a SEPARATE bot via @BotFather — never share with prod)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=
TELEGRAM_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

SUPPORT_CONTACT=

# Staging Sentry DSN (can share project, separate environment tag)
SENTRY_DSN=
